# 이 파일을 .env로 복사하고 값을 채워주세요
# cp .env.example .env

# 필수: 강력한 랜덤 시크릿 키 (python -c "import secrets; print(secrets.token_urlsafe(50))")
DJANGO_SECRET_KEY=your-secret-key-here

# 개발 시 True, 운영 시 반드시 False
DJANGO_DEBUG=True

# 운영 시 도메인 목록 (쉼표 구분), 개발 시 비워둬도 됨
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com
